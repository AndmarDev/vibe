{
  "name": "vibe",
  "private": true,
  "scripts": {
    "prune": "pnpm store prune",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "build": "pnpm -r run build",
    "build:cleanup": "pnpm -r run build:cleanup",
    "typecheck": "pnpm -r run typecheck",
    "cbuild": "pnpm -r run build:cleanup && pnpm run build:all",
    "test": "pnpm --filter @app/test-hub test",
    "test:watch": "pnpm --filter @app/test-hub test:watch"
  },
  "packageManager": "pnpm@10.26.2",
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
